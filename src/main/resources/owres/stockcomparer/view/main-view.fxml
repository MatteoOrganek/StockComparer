<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.HBox?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="owres.stockcomparer.application.controller.MainController">
    <HBox spacing="10" alignment="TOP_RIGHT">
        <ComboBox fx:id="dropdownStock" onAction="#handleDropdownStock" promptText="Select stock" prefWidth="200.0"/>
        <ComboBox fx:id="dropdownProfile" onAction="#handleDropdownProfile" promptText="Select profile" prefWidth="200.0"/>
    </HBox>
    <VBox fx:id="graphContainer" VBox.vgrow="ALWAYS"/>
</VBox>
